# ==============================================================================
# SJF Catalog ‚Äî Environment Template  (Zero-Trust)
# ------------------------------------------------------------------------------
# Copy to `.env.local` (git-ignored) and fill REAL values there ‚Äî OR set them in
# the Conda env: `conda env config vars set -n sjfu-catalog KEY="value"`.
# NEVER put real secrets in this file or commit them. This template is the
# hand-off contract: it lists every variable the app needs, with no values.
#
# Legend:  [public] safe to expose to the browser   [secret] server-only
# ==============================================================================

# ‚îÄ‚îÄ Supabase: spoke project `zkoimkcctqigisfeqlpv` ("SJF-Catalog-Project", us-east-2)
NEXT_PUBLIC_SUPABASE_URL=https://zkoimkcctqigisfeqlpv.supabase.co   # [public]
NEXT_PUBLIC_SUPABASE_ANON_KEY=                                      # [public] publishable anon key
SUPABASE_SERVICE_ROLE_KEY=                                          # [secret] admin / migrations only
DATABASE_URL=                                                      # [secret] pooled Postgres connection string

# ‚îÄ‚îÄ Embeddings: gemini-embedding-001 @ 1536 (query + stored share one space)
#    TWO interchangeable auth paths ‚Äî same model, same dimension:
#    (A) Vertex AI, KEYLESS ‚Äî Adam's business account (API keys disallowed by org policy).
#        Set GCP_PROJECT_ID + ADC/SA below; leave GEMINI_API_KEY blank. This is the default.
#    (B) Google AI Studio API key ‚Äî for CLIENT HANDOFF. Set GEMINI_API_KEY and the app +
#        `npm run reembed` use the key path instead. Pick with `reembed --provider vertex|gemini`.
GEMINI_API_KEY=                                                    # [secret] path (B) only ‚Äî leave blank when using Vertex

# ‚îÄ‚îÄ FastAPI swarm / catalog-production agent
NEXT_PUBLIC_SWARM_API_URL=                                         # [public] base URL of the swarm API
SWARM_API_TOKEN=                                                   # [secret] auth for server‚Üíswarm calls

# ‚îÄ‚îÄ Generation LLM (GCP-hosted: Vertex Gemini or self-hosted Cloud Run GPU)
GCP_PROJECT_ID=                                                    # [secret]
GOOGLE_APPLICATION_CREDENTIALS=                                    # [secret] path to service-account json (never commit the json)

# ‚îÄ‚îÄ GCS assets (catalog PDFs / intake) ‚Äî bucket already exists hub-side
GCS_BUCKET=sjfu-assets                                             # [public]

# ‚îÄ‚îÄ App
APP_TENANT_ID=SJFU                                                 # [public] canonical tenant id
